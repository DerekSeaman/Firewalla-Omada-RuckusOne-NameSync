[DEFAULT]

# ---------------------------------------------------------------------------
# Firewalla (required)
# ---------------------------------------------------------------------------

# Generate a token in the Firewalla app or web portal under:
# Account → API Settings → Create token
FIREWALLA_API_TOKEN=your_token_here

# The subdomain of your MSP portal URL.
# If your portal is at https://your-msp-id.firewalla.net, the MSP ID is your-msp-id.
FIREWALLA_MSP_ID=your-msp-id

# ---------------------------------------------------------------------------
# Omada SDN controller (required only when syncing to Omada)
# ---------------------------------------------------------------------------

# Full URL of your Omada controller, including port.
# Software controller default port: 8043
# Hardware controller default port: 443
OMADA_URL=https://192.168.1.1:8043

# Omada admin credentials
OMADA_USERNAME=your_omada_username
OMADA_PASSWORD=your_omada_password

# Site name to sync (shown in the Omada controller UI). Default: Default
OMADA_SITE=Default

# Set to 'false' if your controller uses a self-signed certificate.
# Warning: disabling verification exposes you to MITM attacks on your LAN.
OMADA_VERIFY_SSL=true

# ---------------------------------------------------------------------------
# Ruckus One (required only when syncing to Ruckus One)
# ---------------------------------------------------------------------------

# Create an Application Token in the Ruckus One portal:
# Administration → Account Management → Settings → Application Tokens
RUCKUS_CLIENT_ID=your_client_id_here
RUCKUS_CLIENT_SECRET=your_client_secret_here

# 32-character tenant ID — found in your Ruckus One portal URL:
# https://ruckus.cloud/{tenant_id}/t/dashboard
RUCKUS_TENANT_ID=your_32_char_tenant_id_here

# Region where your Ruckus One account is hosted: us | eu | asia
RUCKUS_REGION=us
